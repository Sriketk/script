{
  "name": "script",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "next-themes": "^0.4.6",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "dev:zero": "turbo -F zero dev",
    "db:push": "turbo -F @script/db db:push",
    "db:studio": "turbo -F @script/db db:studio",
    "db:generate": "turbo -F @script/db db:generate",
    "db:migrate": "turbo -F @script/db db:migrate",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@script/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@script/config": "workspace:*",
    "@types/bun": "catalog:",
    "husky": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.6.3"
  },
  "packageManager": "bun@1.3.5"
}
